---
import { Picture } from 'astro:assets';
import BaseButton from './BaseButton.astro';
import { heroImage, HERO_PRELOAD_WIDTH, HERO_QUALITY } from '../lib/hero';
---

<section class="relative overflow-hidden border-b border-line bg-canvas py-14 md:py-20">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-80 bg-gradient-to-b from-lime-50 to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto grid w-[min(1120px,calc(100%-32px))] items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="reveal max-w-3xl">
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <span class="sticker">Roadmap · Komunitas</span>
        <span class="meta-row">indopensource.org / open-source · ID</span>
      </div>

      <h1 class="display-xl m-0 text-ink">
        Komunitas<br />Open&nbsp;Source<br /><span class="text-brand">Indonesia</span>
      </h1>

      <p class="mt-7 max-w-2xl text-[clamp(1.05rem,1.7vw,1.25rem)] leading-8 text-muted">
        Rumah terbuka untuk merawat daftar proyek, mendokumentasikan falsafah,
        menulis pembelajaran, dan menghubungkan kontributor open source Indonesia.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <BaseButton href="/projects/">Lihat proyek</BaseButton>
        <BaseButton href="https://github.com/orgs/IndopenSource/projects" variant="secondary">Roadmap GitHub</BaseButton>
      </div>

      <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3 max-sm:grid-cols-1">
        <div class="rounded-xl border border-line bg-paper p-4 shadow-sm">
          <dt class="meta-row uppercase tracking-[0.08em]">Direktori</dt>
          <dd class="mt-1 font-semibold text-ink">Awesome ID</dd>
        </div>
        <div class="rounded-xl border border-line bg-paper p-4 shadow-sm">
          <dt class="meta-row uppercase tracking-[0.08em]">Build</dt>
          <dd class="mt-1 font-semibold text-ink">Static · Astro</dd>
        </div>
        <div class="rounded-xl border border-line bg-paper p-4 shadow-sm">
          <dt class="meta-row uppercase tracking-[0.08em]">Lisensi</dt>
          <dd class="mt-1 font-semibold text-ink">Open / Publik</dd>
        </div>
      </dl>
    </div>

    <div class="reveal reveal-2 relative mx-auto w-full max-w-xl lg:mx-0">
      <div class="absolute -inset-5 rounded-[2rem] bg-lime-100/70 blur-2xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-3xl border border-line bg-paper p-2 shadow-[0_24px_60px_rgba(16,24,40,0.14)]">
        <Picture
          src={heroImage}
          formats={['avif', 'webp']}
          widths={[640, 960, HERO_PRELOAD_WIDTH]}
          sizes="(min-width: 1024px) 42vw, 100vw"
          quality={HERO_QUALITY}
          alt=""
          aria-hidden="true"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/3] w-full rounded-[1.1rem] object-cover"
        />
      </div>
    </div>
  </div>
</section>
