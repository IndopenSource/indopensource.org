---
import { normalizeHref } from '../lib/urls';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'light';
}

const { href, variant = 'primary' } = Astro.props;
const targetHref = normalizeHref(href);

/*
 * Riso sticker-buttons: flat spot-ink fill, THICK ink border, HARD offset block
 * shadow, mono uppercase label. `.riso-hover` nudges the button into its shadow
 * on hover (print misregistration). Verified contrast:
 *   primary   white on brand 7.27:1
 *   secondary ink on canvas/paper >=14:1
 *   light     brand-dark on paper 10.93:1
 */
const variants = {
  primary: 'border-brand bg-brand text-white shadow-sm hover:border-brand-dark hover:bg-brand-dark',
  secondary: 'border-line bg-paper text-ink shadow-sm hover:border-gray-300 hover:bg-canvas',
  light: 'border-white/70 bg-white text-brand-dark shadow-sm hover:bg-lime-50'
};
---

<a
  class={`inline-flex min-h-11 items-center justify-center rounded-lg border px-5 text-sm font-semibold transition duration-150 hover:-translate-y-0.5 focus-visible:outline-offset-2 ${variants[variant]}`}
  href={targetHref}
>
  <slot />
</a>
