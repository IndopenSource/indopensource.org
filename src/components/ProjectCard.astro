---
import { normalizeHref, withBase } from '../lib/urls';
import { projectSlug, type Project } from '../lib/projects';

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const status = project.archived ? 'Archived' : project.language || 'Project';
const updatedDate = project.pushedAt || project.updatedAt;
const updatedLabel = updatedDate
  ? new Intl.DateTimeFormat('id-ID', { dateStyle: 'medium' }).format(new Date(updatedDate))
  : '';
const visibleTopics = (project.topics || []).slice(0, 4);
const detailUrl = withBase(`/projects/${projectSlug(project.fullName)}/`);
const repoName = project.fullName.split('/').at(-1) || project.fullName;
const homepageUrl = project.homepage ? normalizeHref(project.homepage) : '';
const createdYear = project.createdAt ? new Date(project.createdAt).getFullYear() : null;
---

<article
  class:list={[
    'project-card group relative flex flex-col rounded-xl border border-line bg-paper p-5 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg focus-within:ring-2 focus-within:ring-brand/30',
    compact && 'h-full'
  ]}
  data-project-card
  data-name={project.fullName.toLowerCase()}
  data-description={project.description.toLowerCase()}
  data-owner={(project.owner || '').toLowerCase()}
  data-language={(project.language || '').toLowerCase()}
  data-topics={(project.topics || []).join(' ').toLowerCase()}
  data-stars={project.stars}
  data-updated={updatedDate}
  data-release={project.latestRelease?.publishedAt || ''}
>
  <div class="flex items-start gap-3">
    {
      project.ownerAvatarUrl && (
        <img
          class="size-11 shrink-0 rounded-lg border border-line bg-canvas object-cover"
          src={project.ownerAvatarUrl}
          alt=""
          width="44"
          height="44"
          loading="lazy"
          decoding="async"
        />
      )
    }
    <div class="min-w-0 grow">
      <div class="flex flex-wrap items-center gap-2">
        <span class="sticker">{status}</span>
        {
          project.latestRelease ? (
            <a class="stamp relative z-10 transition-colors hover:bg-sun" href={project.latestRelease.url}>
              Rilis {project.latestRelease.tagName}
            </a>
          ) : null
        }
      </div>
      {project.owner && <p class="meta-row mt-3 font-semibold text-brand-dark">{project.owner}/</p>}
      <h3 class="mt-1 text-xl font-bold text-ink">
        <a
          class="hover:text-brand focus:outline-none focus-visible:underline after:absolute after:inset-0 after:z-0 focus-visible:after:ring-2 focus-visible:after:ring-accent"
          href={detailUrl}
          aria-label={`Buka detail ${project.fullName}`}
        >{repoName}</a>
      </h3>
    </div>
  </div>
  <p class="mt-4 leading-7 text-muted">{project.description}</p>
  {
    visibleTopics.length > 0 && (
      <div class="meta-row mt-4 flex flex-wrap gap-x-3 gap-y-1 font-semibold text-brand-dark">
        {visibleTopics.map((topic) => <span>#{topic}</span>)}
      </div>
    )
  }
  {!project.syncFailed && (
    <div class="meta-row mt-4 flex flex-wrap gap-x-3 gap-y-1 text-muted">
      <span>Lisensi {project.licenseSpdx || '—'}</span>
      <span>{project.openIssues ?? 0} issue</span>
      <span>{project.openPullRequests ?? 0} PR</span>
      <span>{project.subscribers ?? 0} watcher</span>
      <span>Health {project.communityHealth ?? '—'}%</span>
      {createdYear && <span>Sejak {createdYear}</span>}
    </div>
  )}
  <hr class="rule mt-auto pt-4" />
  <div class="mt-4 flex flex-wrap items-center gap-2">
    <span class="rounded-md border border-line bg-canvas px-2 py-1 font-mono text-xs font-semibold text-ink">
      ★ {project.stars.toLocaleString('id-ID')}
    </span>
    <span class="rounded-md border border-line bg-canvas px-2 py-1 font-mono text-xs font-semibold text-ink">
      ⑂ {project.forks.toLocaleString('id-ID')}
    </span>
    {updatedLabel && (
      <span class="rounded-md border border-line bg-canvas px-2 py-1 font-mono text-xs font-semibold text-muted">{updatedLabel}</span>
    )}
    {homepageUrl && (
      <a class="relative z-10 ml-auto rounded-md border border-brand bg-brand px-2.5 py-1.5 text-xs font-semibold text-paper transition-colors hover:bg-brand-dark" href={homepageUrl}>
        Situs ↗
      </a>
    )}
  </div>
</article>
