---
interface Props {
  status?: string;
  title: string;
}

const { status, title } = Astro.props;
---

<article class="flex flex-col rounded-xl border border-line bg-paper p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
  {status && <span class="sticker self-start">{status}</span>}
  <h3 class={`display-sm text-ink ${status ? 'mt-3' : ''}`}>{title}</h3>
  <div class="mt-2 leading-7 text-muted">
    <slot />
  </div>
</article>
