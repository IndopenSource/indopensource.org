---
// RISO-EDITORIAL restyle: a printed zine timeline. Each milestone is a numbered
// editorial block (01/02/03 via `.section-number`) with a thick ink rule, a sun
// sticker status chip, mono metadata, and a hard-offset card on the right. The
// container auto-staggers its rows on load via `.reveal-stagger`. Content data
// preserved verbatim — only restyled. Contrast: ink/muted on paper >=6.7:1,
// ink on sun 8.87:1 (sticker label).
const items = [
  ['Milestone 1', 'Foundation website', 'Setup repo, desain halaman inti, SEO dasar, dan build statis.', 'Selesai'],
  ['Milestone 2', 'Project directory', 'Sinkronisasi dari awesome-indonesia, filter, pencarian, dan detail proyek.', 'Berjalan'],
  ['Milestone 3', 'Knowledge dan forum', 'Blog repo, editorial flow, dan integrasi GitHub Discussions.', 'Direncanakan']
];
---

<ol class="reveal-stagger grid list-none gap-4 p-0">
  {
    items.map(([milestone, title, description, status], index) => (
      <li class="group grid grid-cols-[auto_minmax(0,1fr)] gap-5 rounded-xl border border-line bg-paper p-6 shadow-sm max-md:gap-4 max-sm:grid-cols-1">
        <span class="flex size-12 items-center justify-center rounded-full bg-sun font-mono text-sm font-bold tabular-nums text-brand-dark" aria-hidden="true">
          {String(index + 1).padStart(2, '0')}
        </span>
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-3">
            <span class="meta-row font-bold uppercase tracking-[0.08em] text-brand-dark">{milestone}</span>
            <span class="sticker">{status}</span>
          </div>
          <h3 class="display-sm mt-2 text-ink">{title}</h3>
          <p class="mt-3 max-w-2xl text-lg leading-7 text-muted">{description}</p>
        </div>
      </li>
    ))
  }
</ol>
