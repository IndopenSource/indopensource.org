---
import { Picture } from 'astro:assets';
import { withBase } from '../lib/urls';
import brandIcon from '../assets/brand/icon-192.png';

const navItems = [
  ['Home', '/'],
  ['Falsafah', '/falsafah/'],
  ['Proyek', '/projects/'],
  ['Belajar', '/belajar/'],
  ['Kontribusi', '/cara-berkontribusi/'],
  ['Blog', '/blog/'],
  ['Forum', '/forum/'],
  ['FAQ', '/faq/'],
  ['Donasi', '/donasi/'],
  ['Kontak', '/contact/']
];

const mobileNavItems = [
  ['Home', '/', 'ph-house'],
  ['Proyek', '/projects/', 'ph-grid-four'],
  ['Belajar', '/belajar/', 'ph-books'],
  ['Blog', '/blog/', 'ph-article'],
  ['Forum', '/forum/', 'ph-chats-circle']
];

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPathWithoutBase = currentPath.replace(new RegExp(`^${baseUrl.replace(/\/$/, '')}`), '') || '/';
---

{/*
  EDITORIAL MASTHEAD — riso-zine wordmark stamp, mono nav row, thick ink bottom
  rule. Sticky cream field; the global body grain shows through the translucent
  paper so the bar reads as printed paper, not glass. All depth via design-system
  utilities (.rule, .riso-shadow-sm, .sticker, .meta-row) — no inline styles.
*/}
<header class="sticky top-0 z-20 border-b border-line bg-paper/90 backdrop-blur-xl">
  <nav
    class="mx-auto flex min-h-16 w-[min(1120px,calc(100%-32px))] items-center justify-between gap-6 py-3"
    aria-label="Navigasi utama"
  >
    {/* Wordmark = stamped logo tile + editorial display name + mono kicker */}
    <a
      class="group inline-flex items-center gap-3 rounded-xl focus-visible:outline-offset-4"
      href={withBase('/')}
    >
      <Picture
        src={brandIcon}
        formats={['avif', 'webp']}
        widths={[36, 72]}
        sizes="36px"
        width={36}
        height={36}
        alt=""
        loading="eager"
        class="size-9 rounded-lg border border-line bg-paper object-contain shadow-sm"
      />
      <span class="flex flex-col leading-none">
        <span class="font-display text-xl font-extrabold tracking-tight text-ink"><span class="text-brand">Indo</span>penSource</span>
        <span class="meta-row mt-0.5 text-muted max-sm:hidden">Komunitas Open Source Indonesia</span>
      </span>
    </a>

    {/* Desktop nav — mono uppercase labels, riso-underline reveal, sticker active state */}
    <div class="flex items-center justify-end gap-1 rounded-xl border border-line bg-canvas p-1 max-md:hidden">
      {
        navItems.map(([label, href]) => {
          const isCurrent = currentPathWithoutBase === href;
          return isCurrent ? (
            <a
              class="inline-flex items-center rounded-lg bg-paper px-3 py-2 text-sm font-semibold text-brand-dark shadow-sm ring-1 ring-line"
              href={withBase(href)}
              aria-current="page"
            >
              {label}
            </a>
          ) : (
            <a
              class="inline-flex items-center rounded-lg px-3 py-2 text-sm font-medium text-muted transition-colors hover:bg-paper hover:text-ink"
              href={withBase(href)}
            >
              {label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>

{/*
  MOBILE DOCK — five icon-first destinations in a native bottom-tab layout.
*/}
<nav
  class="fixed inset-x-3 bottom-3 z-30 hidden overflow-hidden rounded-2xl border border-line bg-paper/95 shadow-[0_16px_40px_rgba(16,24,40,0.18)] backdrop-blur-xl max-md:grid max-md:grid-cols-5"
  style="padding-bottom: env(safe-area-inset-bottom, 0px)"
  aria-label="Navigasi mobile"
>
  {
    mobileNavItems.map(([label, href, icon]) => {
      const isCurrent = currentPathWithoutBase === href;
      return (
        <a
          class:list={[
            'flex min-h-16 flex-col items-center justify-center gap-1 px-1 py-2 text-center text-[0.65rem] font-semibold transition-colors',
            isCurrent ? 'bg-sun text-brand-dark' : 'text-muted hover:bg-canvas hover:text-ink'
          ]}
          href={withBase(href)}
          aria-current={isCurrent ? 'page' : undefined}
        >
          <i class:list={['ph-fill text-2xl leading-none', icon]} aria-hidden="true"></i>
          {label}
        </a>
      );
    })
  }
</nav>
