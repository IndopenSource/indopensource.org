---
import BlogArticlePage from '../../../components/BlogArticlePage.astro';
import blogPosts from '../../../data/blog-posts.json';
import { articleLanguage, articleTranslations, isPublished, type BlogPost } from '../../../lib/content';

export function getStaticPaths() {
  const posts = blogPosts as BlogPost[];
  return posts
    .filter((post) => articleLanguage(post) === 'en')
    .map((post) => ({
      params: { slug: isPublished(post) ? post.slug : `preview/${post.slug}` },
      props: { post, translations: articleTranslations(posts, post) }
    }));
}

const { post, translations } = Astro.props;
---

<BlogArticlePage post={post} translations={translations} />
