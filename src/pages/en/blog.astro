---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BaseButton from '../../components/BaseButton.astro';
import PageHeader from '../../components/PageHeader.astro';
import blogPosts from '../../data/blog-posts.json';
import { withBase } from '../../lib/urls';
import { articleHref, articleLanguage, isPublished, type BlogPost } from '../../lib/content';

const publishedPosts = (blogPosts as BlogPost[]).filter(
  (post) => isPublished(post) && articleLanguage(post) === 'en'
);
---

<BaseLayout
  title="English Articles - IndopenSource"
  description="English articles from Indonesia's open source community."
  language="en"
  alternates={[
    { lang: 'id', href: '/blog/' },
    { lang: 'en', href: '/en/blog/' }
  ]}
>
  <PageHeader eyebrow="Blog" title="Open source stories from Indonesia.">
    <p>English editions of selected IndopenSource articles.</p>
    <div class="mt-7 flex flex-wrap gap-3 text-ink">
      <BaseButton href="/blog/" variant="secondary">Artikel Bahasa Indonesia</BaseButton>
      <BaseButton href="https://github.com/IndopenSource/Blog-IndopenSource">Open blog repository</BaseButton>
    </div>
  </PageHeader>

  <section class="py-16 md:py-20">
    <div class="mx-auto grid w-[min(1120px,calc(100%-32px))] gap-6">
      {publishedPosts.map((post) => {
        const articleUrl = articleHref(post);
        const thumbnail = post.thumbnail || '/brand/indopensource-hero.jpg';
        const thumbnailUrl = /^https?:\/\//.test(thumbnail) ? thumbnail : withBase(thumbnail);
        const publishedDate = post.releasedAt
          ? new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' }).format(new Date(post.releasedAt))
          : '';

        return (
          <article class="riso-hover riso-shadow grid overflow-hidden border-2 border-ink bg-paper md:grid-cols-[minmax(0,1fr)_minmax(280px,400px)]">
            <div class="flex flex-col p-6 md:p-8">
              <div class="meta-row flex flex-wrap items-center gap-x-3 gap-y-1 font-semibold text-muted uppercase tracking-[0.06em]">
                <span class="text-brand-dark">{articleUrl}</span>
                {publishedDate && <><span aria-hidden="true">·</span><span>{publishedDate}</span></>}
              </div>
              <h2 class="display-md mt-4 max-w-2xl text-ink">
                <a class="hover:text-brand" href={articleUrl}>{post.title}</a>
              </h2>
              <p class="mt-4 max-w-xl font-body text-lg leading-8 text-muted">{post.description}</p>
              <div class="mt-7">
                <BaseButton href={articleUrl} variant="secondary">Read article</BaseButton>
              </div>
            </div>
            <a class="relative min-h-64 border-ink bg-ink max-md:border-t-2 md:border-l-2" href={articleUrl} aria-label={`Read ${post.title}`}>
              <img
                class="h-full min-h-64 w-full object-cover mix-blend-luminosity opacity-95"
                src={thumbnailUrl}
                alt={`Article thumbnail: ${post.title}`}
                width="1280"
                height="720"
                loading="lazy"
                decoding="async"
              />
            </a>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
