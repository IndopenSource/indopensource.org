---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseButton from '../components/BaseButton.astro';
import PageHeader from '../components/PageHeader.astro';

const formats = [
  ['Temu komunitas', 'Berbagi kabar proyek, menemukan rekan kerja, dan mempertemukan komunitas lokal.'],
  ['Klinik kontribusi', 'Sesi santai untuk membedah issue, dokumentasi, atau pull request pertama.'],
  ['Workshop terbuka', 'Belajar praktik secara langsung dengan materi dan hasil yang dapat dipublikasikan kembali.']
];
---

<BaseLayout title="Event - IndopenSource" description="Ruang untuk agenda meetup, workshop, dan sesi kerja bersama IndopenSource.">
  <PageHeader eyebrow="Event" title="Belum ada agenda aktif—dan itu bisa diubah bersama."><p>Halaman ini menampung format kegiatan yang ingin kami jalankan. Saat ada agenda, ia akan dicatat terbuka di sini dan di ruang diskusi.</p></PageHeader>
  <section class="bg-canvas py-16 md:py-20"><div class="mx-auto w-[min(1120px,calc(100%-32px))]"><div class="mb-10 grid gap-5 border-y-[3px] border-ink py-6 md:grid-cols-[auto_1fr]"><span class="section-number text-brand-dark">00</span><div><span class="sticker">Kalender terbuka</span><h2 class="display-md mt-3">Belum ada agenda yang diumumkan.</h2><p class="mt-3 font-body text-lg leading-8 text-muted">Saat kegiatan tersedia, detail waktu, format, dan catatan pasca-acara akan dicatat di halaman ini agar mudah diikuti ulang.</p></div></div><div class="mb-8 flex items-center gap-3"><span class="sticker">Format awal</span><span class="rule grow"></span></div><div class="grid gap-4 md:grid-cols-3">{formats.map(([title, body]) => <article class="riso-shadow border-2 border-ink bg-paper p-6"><h2 class="display-sm text-ink">{title}</h2><p class="mt-3 font-body leading-7 text-muted">{body}</p></article>)}</div><div class="mt-10"><BaseButton href="https://github.com/orgs/IndopenSource/discussions">Usulkan kegiatan</BaseButton></div></div></section>
</BaseLayout>
