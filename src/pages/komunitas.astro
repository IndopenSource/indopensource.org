---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseButton from '../components/BaseButton.astro';
import PageHeader from '../components/PageHeader.astro';
import communitiesData from '../data/communities.json';
import { safeHref } from '../lib/urls';

interface Community {
  name: string;
  description: string;
  focus?: string;
  location?: string;
  url: string;
}

const communities = communitiesData as Community[];
---

<BaseLayout
  title="Direktori Komunitas Open Source Indonesia - IndopenSource"
  description="Direktori terbuka komunitas open source Indonesia yang dapat ditambahkan melalui pull request."
>
  <PageHeader eyebrow="Komunitas" title="Direktori komunitas open source Indonesia.">
    <p>Tempat menemukan komunitas, kelompok pengguna, dan ruang belajar terbuka dari berbagai daerah dan bidang. Daftarnya sedang kami siapkan bersama.</p>
  </PageHeader>

  <section class="border-b-[3px] border-ink bg-paper py-16 md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      {communities.length === 0 ? (
        <div class="riso-shadow border-2 border-ink bg-canvas p-8 md:p-12">
          <span class="sticker">Segera hadir</span>
          <h2 class="display-md mt-5 text-ink">Belum ada komunitas yang ditampilkan.</h2>
          <p class="mt-4 max-w-2xl font-body text-lg leading-8 text-muted">Kami sengaja memulai dari daftar kosong agar setiap entri punya sumber, tautan aktif, dan diajukan secara terbuka, bukan hasil asumsi.</p>
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {communities.map((community) => (
            <a class="riso-hover riso-shadow border-2 border-ink bg-canvas p-6" href={safeHref(community.url)} target="_blank" rel="noopener noreferrer">
              <h2 class="display-sm text-ink">{community.name}</h2>
              <p class="mt-3 font-body leading-7 text-muted">{community.description}</p>
              <div class="meta-row mt-5 flex flex-wrap gap-3 text-brand-dark">
                {community.focus && <span>{community.focus}</span>}
                {community.location && <span>{community.location}</span>}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="bg-canvas py-16 md:py-20">
    <div class="mx-auto grid w-[min(1120px,calc(100%-32px))] gap-8 lg:grid-cols-[minmax(0,1fr)_380px]">
      <div>
        <span class="sticker">Tambahkan komunitas</span>
        <h2 class="display-md mt-4 text-ink">Buka pull request di repository website.</h2>
        <p class="mt-4 max-w-2xl font-body text-lg leading-8 text-muted">Pengurus atau anggota komunitas boleh mengusulkan entri. Sertakan informasi yang bisa diverifikasi dan pastikan Anda memang berwenang membagikan profil tersebut.</p>
        <ol class="mt-7 grid gap-4 font-body text-lg leading-8 text-muted">
          <li><strong class="font-display text-ink">01 — Fork repository.</strong> Buka <code class="rounded bg-paper px-1.5 py-0.5 font-mono text-sm">IndopenSource/indopensource.org</code> lalu buat branch baru.</li>
          <li><strong class="font-display text-ink">02 — Tambahkan data.</strong> Edit <code class="rounded bg-paper px-1.5 py-0.5 font-mono text-sm">src/data/communities.json</code> dengan nama, deskripsi, wilayah atau fokus, dan tautan resmi.</li>
          <li><strong class="font-display text-ink">03 — Verifikasi lokal.</strong> Jalankan <code class="rounded bg-paper px-1.5 py-0.5 font-mono text-sm">npm test</code> dan <code class="rounded bg-paper px-1.5 py-0.5 font-mono text-sm">npm run build</code>.</li>
          <li><strong class="font-display text-ink">04 — Buka PR ke main.</strong> Jelaskan hubungan Anda dengan komunitas serta sumber yang dapat dipakai reviewer untuk memeriksa entri.</li>
        </ol>
      </div>
      <aside class="riso-shadow border-2 border-ink bg-paper p-6">
        <i class="ph-fill ph-git-pull-request text-4xl text-brand" aria-hidden="true"></i>
        <h3 class="display-sm mt-4 text-ink">Siap menambahkan?</h3>
        <p class="mt-3 font-body leading-7 text-muted">Mulai dari perubahan kecil: satu komunitas, satu sumber resmi, satu pull request yang mudah diperiksa.</p>
        <div class="mt-6 flex flex-col items-start gap-3">
          <BaseButton href="https://github.com/IndopenSource/indopensource.org">Buka repository</BaseButton>
          <a class="font-semibold text-brand underline decoration-2 underline-offset-4" href="https://github.com/IndopenSource/indopensource.org/compare" target="_blank" rel="noopener noreferrer">Buka halaman compare ↗</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
