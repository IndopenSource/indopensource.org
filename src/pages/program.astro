---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseButton from '../components/BaseButton.astro';
import PageHeader from '../components/PageHeader.astro';

const programs = [
  ['Peta Proyek', 'Direktori dan kurasi proyek yang membantu orang menemukan perangkat, komunitas, dan maintainernya.', 'Berjalan'],
  ['Pengetahuan Terbuka', 'Artikel, buku, dan catatan teknis yang membuat pengalaman praktis tidak hilang begitu saja.', 'Berjalan'],
  ['Klinik Perawatan', 'Ruang eksperimental untuk membahas dokumentasi, issue triage, rilis, dan keberlanjutan proyek.', 'Dirancang'],
  ['Temu Komunitas', 'Format meetup, workshop, atau sesi kerja bersama yang dapat dijalankan bersama komunitas lokal.', 'Dirancang']
];
---

<BaseLayout title="Program & Inisiatif - IndopenSource" description="Program awal IndopenSource untuk kurasi proyek, pengetahuan terbuka, dan perawatan komunitas.">
  <PageHeader eyebrow="Program" title="Kerja kecil yang bisa dikembangkan bersama."><p>Ini adalah peta program awal, bukan janji aktivitas yang sudah berjalan. Prioritas akan dibuka secara bertahap lewat diskusi publik.</p></PageHeader>
  <section class="bg-canvas py-16 md:py-20"><div class="mx-auto w-[min(1120px,calc(100%-32px))]"><div class="mb-9 flex flex-wrap items-end justify-between gap-5 border-b-[3px] border-ink pb-5"><div><span class="sticker">Program register</span><h2 class="display-md mt-4">Empat arah kerja.</h2></div><span class="font-mono text-sm font-bold uppercase tracking-[0.06em] text-brand-dark">02 berjalan / 02 dirancang</span></div><div class="grid gap-4 md:grid-cols-2">{programs.map(([title, body, status]) => <article class="riso-shadow border-2 border-ink bg-paper p-6"><div class="flex items-center justify-between gap-4"><span class="sticker">{status}</span><span class="meta-row text-brand-dark">inisiatif</span></div><h2 class="display-sm mt-5 text-ink">{title}</h2><p class="mt-3 font-body leading-7 text-muted">{body}</p></article>)}</div><div class="mt-10"><BaseButton href="https://github.com/orgs/IndopenSource/discussions">Usulkan program</BaseButton></div></div></section>
</BaseLayout>
