---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfoCard from '../components/InfoCard.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Contact - IndopenSource">
  <PageHeader eyebrow="Contact" title="Mulai dari GitHub.">
    <p>
      Kontak awal diarahkan ke GitHub agar semua permintaan, kontribusi, dan ide roadmap
      punya jejak terbuka yang bisa ditindaklanjuti komunitas.
    </p>
  </PageHeader>
  <section class="py-18">
    <div class="mx-auto grid w-[min(1120px,calc(100%-32px))] grid-cols-3 gap-4 max-lg:grid-cols-1">
      <InfoCard title="Organization">
        <p><a href="https://github.com/IndopenSource">github.com/IndopenSource</a></p>
      </InfoCard>
      <InfoCard title="Roadmap">
        <p><a href="https://github.com/orgs/IndopenSource/projects">GitHub Projects IndopenSource</a></p>
      </InfoCard>
      <InfoCard title="Forum">
        <p><a href="https://github.com/orgs/IndopenSource/discussions">GitHub Discussions IndopenSource</a></p>
      </InfoCard>
    </div>
  </section>
</BaseLayout>
