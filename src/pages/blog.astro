---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog - IndopenSource">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>Catatan kerja open source Indonesia.</h1>
      <p>
        Blog direncanakan memakai repo khusus seperti
        <a href="https://github.com/IndopenSource/Blog-IndopenSource">IndopenSource/Blog-IndopenSource</a>
        agar tulisan, review, dan publikasi bisa punya alur kontribusi sendiri.
      </p>
    </div>
  </section>
  <section class="section">
    <div class="container grid">
      <article class="post-card">
        <span class="status">Planned</span>
        <h3>Editorial workflow</h3>
        <p>Template issue, draft PR, reviewer, dan label publikasi.</p>
      </article>
      <article class="post-card">
        <span class="status">Planned</span>
        <h3>Project spotlight</h3>
        <p>Profil proyek Indonesia yang aktif, berguna, dan mudah diikuti kontributor baru.</p>
      </article>
      <article class="post-card">
        <span class="status">Planned</span>
        <h3>Learning notes</h3>
        <p>Catatan praktis tentang maintenance, release, dokumentasi, dan komunitas.</p>
      </article>
    </div>
  </section>
</BaseLayout>
