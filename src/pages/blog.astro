---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfoCard from '../components/InfoCard.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Blog - IndopenSource">
  <PageHeader eyebrow="Blog" title="Catatan kerja open source Indonesia.">
    <p>
      Blog direncanakan memakai repo khusus seperti
      <a class="font-bold text-brand hover:text-brand-dark" href="https://github.com/IndopenSource/Blog-IndopenSource">IndopenSource/Blog-IndopenSource</a>
      agar tulisan, review, dan publikasi bisa punya alur kontribusi sendiri.
    </p>
  </PageHeader>
  <section class="py-18">
    <div class="mx-auto grid w-[min(1120px,calc(100%-32px))] grid-cols-3 gap-4 max-lg:grid-cols-1">
      <InfoCard status="Planned" title="Editorial workflow">
        <p>Template issue, draft PR, reviewer, dan label publikasi.</p>
      </InfoCard>
      <InfoCard status="Planned" title="Project spotlight">
        <p>Profil proyek Indonesia yang aktif, berguna, dan mudah diikuti kontributor baru.</p>
      </InfoCard>
      <InfoCard status="Planned" title="Learning notes">
        <p>Catatan praktis tentang maintenance, release, dokumentasi, dan komunitas.</p>
      </InfoCard>
    </div>
  </section>
</BaseLayout>
