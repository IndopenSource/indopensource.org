---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Falsafah - IndopenSource">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Falsafah</p>
      <h1>Open source sebagai gotong royong teknis.</h1>
      <p>
        IndopenSource mengutamakan proyek yang bisa dipelajari, dipakai ulang,
        dirawat bersama, dan memberi manfaat nyata bagi ekosistem teknologi Indonesia.
      </p>
    </div>
  </section>
  <section class="section">
    <div class="container grid">
      <article class="card">
        <h3>Terbuka</h3>
        <p>Kode, diskusi, keputusan, dan roadmap dibuat mudah ditemukan oleh publik.</p>
      </article>
      <article class="card">
        <h3>Terawat</h3>
        <p>Daftar proyek perlu kurasi, metadata yang jelas, dan ritme pembaruan yang sehat.</p>
      </article>
      <article class="card">
        <h3>Bermanfaat</h3>
        <p>Fokus pada perangkat, pustaka, data, dan praktik yang membantu pengguna Indonesia.</p>
      </article>
    </div>
  </section>
</BaseLayout>
