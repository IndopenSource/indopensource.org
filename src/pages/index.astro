---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import InfoCard from '../components/InfoCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BaseButton from '../components/BaseButton.astro';
import LightSvgMotion from '../components/LightSvgMotion.astro';
import projectsData from '../data/projects.json';
import { roadmapPeriods } from '../data/roadmap';
import { heroImage, HERO_PRELOAD_WIDTH, HERO_QUALITY } from '../lib/hero';
import { rankProjectOwners, type Project } from '../lib/projects';
import { withBase } from '../lib/urls';

const projects = projectsData as Project[];
const totalProjects = projects.length;
const topProjects = projects.slice(0, 5);
const roadmapPreview = roadmapPeriods.slice(0, 2);
const topUsers = rankProjectOwners(projects).slice(0, 5);

// Pre-generate the AVIF the hero <Image> will paint as its LCP candidate so we
// can <link rel="preload"> the exact same /_astro/* file from <head>. Same src,
// width and quality as HomeHero's largest `widths` stop -> identical emit ->
// the browser reuses the preloaded download for the LCP paint. (PERF)
const heroPreload = await getImage({
  src: heroImage,
  format: 'avif',
  width: HERO_PRELOAD_WIDTH,
  quality: HERO_QUALITY
});
---

<BaseLayout
  title="Komunitas Open Source Indonesia"
  description="IndopenSource adalah komunitas open source Indonesia untuk direktori proyek, falsafah, blog, forum, dan kolaborasi publik."
  heroPreloadHref={heroPreload.src}
>
  <HomeHero />

  {/* 01 — Editorial block: numbered section index breaks the grid above the
       SectionHeader; orbit accent bleeds off the right. */}
  <section class="relative overflow-hidden border-b-[3px] border-ink bg-paper py-18">
    <LightSvgMotion variant="orbit" />
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <span class="section-number reveal reveal-1 mb-1 block leading-none" aria-hidden="true">01</span>
      <SectionHeader eyebrow="Arsitektur konten" title="Halaman yang dibangun bertahap">
        Situs ini disiapkan sebagai dashboard komunitas: stabil untuk pengunjung,
        tapi tetap dekat dengan alur kerja GitHub yang dipakai IndopenSource.
      </SectionHeader>
      <div class="reveal-stagger grid grid-cols-3 gap-4 max-lg:grid-cols-1">
        <InfoCard status="Live" title="Dasar & arah">
          <p>Falsafah, tentang, tata kelola, dan security menjelaskan cara ruang kerja ini dirawat.</p>
        </InfoCard>
        <InfoCard status={`${totalProjects} repo`} title="Proyek">
          <p>Direktori awal mengambil daftar dari IndopenSource/awesome-indonesia.</p>
        </InfoCard>
        <InfoCard status="Live" title="Pengetahuan & komunitas">
          <p>Blog, Ruang Belajar, Discussions, dan program awal membuka lebih banyak pintu kontribusi.</p>
        </InfoCard>
      </div>
    </div>
  </section>

  {/* Pull-quote interstitial — a printed editorial manifesto OWNED by the ink
       field via `.panel-ink` (its own fine grain) + `.grain-coarse` so this
       dark band carries TWO print frequencies (a heavier press over the fine
       tooth), not one uniform noise. Text re-asserts paper/sun on the dark
       field: paper on ink 15.59:1, sun on ink 8.87:1 (both AA). */}
  <section class="panel-ink grain-coarse relative overflow-hidden border-b-[3px] border-ink py-16 md:py-20">
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="reveal mb-6 flex items-center gap-3">
        <span class="sticker">Falsafah</span>
        <span class="meta-row text-sun">// kenapa kami ada</span>
      </div>
      <blockquote class="reveal max-w-4xl border-l-[5px] border-sun pl-6 font-display text-[clamp(1.7rem,3.6vw,3rem)] font-semibold leading-[1.08] tracking-[-0.015em] text-paper">
        Open source Indonesia itu soal merawat catatan, membuka pintu kontribusi,
        kolaborasi dan menulis ulang cerita teknologi Indonesia secara terbuka.
      </blockquote>
      <div class="reveal mt-6 flex flex-wrap items-center gap-4">
        <p class="meta-row text-sun">— IndopenSource · komunitas terbuka</p>
        <BaseButton href="/falsafah/" variant="light">Baca falsafah</BaseButton>
      </div>
    </div>
  </section>

  {/* Non-teal OWNED field — a full VERMILION manifesto/CTA panel via
       `.panel-vermilion`, so the most-visited page reads as a true multi-ink
       riso pull (ink hero -> ink falsafah -> VERMILION -> canvas -> paper),
       not a teal/cream wash. A `.halftone-coarse` dot screen overprints the
       field as a SECOND-frequency screen (large gauge) over the fine page grain.
       Every text/link on this field is full paper or white — NO opacity dimming
       (paper/90 on vermilion is only 4.47:1) and NO brand/accent ink:
         paper on accent 5.16:1 · white on accent 5.52:1 · ink-on-sun sticker 8.87:1 (all AA). */}
  <section class="panel-vermilion relative overflow-hidden border-b-[3px] border-ink py-16 md:py-20">
    <div
      class="halftone-coarse pointer-events-none absolute inset-0 text-ink/25"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="reveal mb-6 flex flex-wrap items-center gap-3">
        <span class="sticker">Kontribusi</span>
        <span class="meta-row text-paper">// pintu selalu terbuka</span>
      </div>
      <div class="flex items-end justify-between gap-8 max-md:flex-col max-md:items-start">
        <h2 class="reveal display-md m-0 max-w-3xl text-balance text-paper">
          Semua orang boleh ikut menulis catatannya
        </h2>
        <div class="reveal shrink-0 max-md:mt-2">
          <BaseButton href="/cara-berkontribusi/" variant="light">Mulai kontribusi</BaseButton>
        </div>
      </div>
      <p class="reveal mt-6 max-w-2xl font-body text-lg leading-7 text-paper">
        Tidak harus jadi maintainer. Menambah satu repo ke direktori, merapikan
        deskripsi, atau membuka diskusi sudah merawat ekosistem open source
        Indonesia secara terbuka.
      </p>
    </div>
  </section>

  {/* 02 — Roadmap as a printed zine timeline. */}
  <section class="relative overflow-hidden border-b-[3px] border-ink bg-canvas py-18">
    <LightSvgMotion variant="steps" />
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <span class="section-number reveal reveal-1 mb-1 block leading-none" aria-hidden="true">02</span>
      <div class="flex items-start justify-between gap-6 max-md:flex-col max-md:items-start">
        <div class="min-w-0 grow">
          <SectionHeader eyebrow="Roadmap" title="Dua langkah terdekat" />
        </div>
        <div class="shrink-0 max-md:mb-8">
          <BaseButton href="/roadmap/">Lihat selengkapnya</BaseButton>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {roadmapPreview.map((item, index) => (
          <article class="riso-shadow border-2 border-ink bg-paper p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="sticker">{item.period}</span>
              <span class="font-display text-5xl font-black leading-none text-brand/15" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <h3 class="display-sm mt-5 text-ink">{item.title}</h3>
            <ul class="mt-5 space-y-3 font-body leading-7 text-muted">
              {item.items.map((entry) => <li class="flex gap-2"><span class="font-bold text-brand" aria-hidden="true">→</span><span>{entry}</span></li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Printed SUN ribbon — a slim full-bleed band that gives the sun spot-ink a
       real OWNED field (not just sticker chips) and breaks ink->canvas->paper
       into a punchier rhythm before the projects rail. SUN is fill-only, so the
       text stays INK (ink on sun 8.87:1 AA); never paper/accent here. */}
  <aside class="panel-sun relative overflow-hidden border-b-[3px] border-ink py-3" aria-hidden="true">
    <div class="mx-auto flex w-[min(1120px,calc(100%-32px))] flex-wrap items-center gap-x-6 gap-y-1 font-mono text-sm font-bold tracking-[0.04em] text-ink uppercase">
      <span>★ {totalProjects} repo terkurasi</span>
      <span class="text-ink/70">/</span>
      <span>Awesome Indonesia</span>
      <span class="text-ink/70">/</span>
      <span>Open · Publik · Terbuka</span>
    </div>
  </aside>

  {/* 03 — Featured projects rail. */}
  <section class="relative overflow-hidden bg-paper py-18">
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <span class="section-number reveal reveal-1 mb-1 block leading-none" aria-hidden="true">03</span>
      <div class="flex items-start justify-between gap-6 max-md:flex-col max-md:items-start">
        <div class="min-w-0 grow">
          <SectionHeader eyebrow="Awesome Indonesia" title="Repository proyek lokal" >
            Pilihan proyek dari katalog awesome-indonesia.
          </SectionHeader>
        </div>
        <div class="shrink-0 max-md:mb-8">
          <BaseButton href="/projects/" variant="secondary">Buka semua</BaseButton>
        </div>
      </div>
      <div class="-mx-4 overflow-x-auto px-4 pb-4 [scrollbar-width:thin]">
        <div class="flex min-w-full snap-x gap-4">
          {
            topProjects.map((project) => (
              <div class="w-[min(420px,82vw)] shrink-0 snap-start">
                <ProjectCard project={project} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-t-[3px] border-ink bg-canvas py-18">
    <div class="relative mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="flex items-start justify-between gap-6 max-md:flex-col max-md:items-start">
        <div class="min-w-0 grow">
          <SectionHeader eyebrow="Top User" title="Penggerak proyek lokal" >
            Peringkat berdasarkan akumulasi stars pada repository yang tercatat di direktori.
          </SectionHeader>
        </div>
        <div class="shrink-0 max-md:mb-8"><BaseButton href="/users/" variant="secondary">Lihat semua</BaseButton></div>
      </div>
      <div class="-mx-4 overflow-x-auto px-4 pb-4 [scrollbar-width:thin]">
        <div class="flex min-w-full snap-x snap-mandatory gap-4">
          {topUsers.map((user, index) => (
            <a class="riso-hover riso-shadow relative w-[min(280px,78vw)] shrink-0 snap-start border-2 border-ink bg-paper p-5" href={`https://github.com/${user.owner}`} target="_blank" rel="noopener noreferrer">
              <span class="absolute right-4 top-2 font-display text-6xl font-black leading-none text-brand/10" aria-hidden="true">{index + 1}</span>
              <img class="size-14 rounded-xl border-2 border-ink bg-canvas object-cover" src={user.avatarUrl} alt="" width="56" height="56" loading="lazy" decoding="async" />
              <h3 class="mt-4 break-words font-display text-xl font-bold text-ink">{user.owner}</h3>
              <p class="meta-row mt-3 flex flex-wrap gap-3 text-muted"><span>★ {user.stars.toLocaleString('id-ID')}</span><span>{user.repositories} repo</span></p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-t-[3px] border-ink bg-canvas py-16 md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <SectionHeader eyebrow="Jelajahi" title="Ikuti ekosistemnya" >
        Baca perkembangannya, kenali penggeraknya, atau bantu menjaga ruang terbuka ini.
      </SectionHeader>
      <div class="grid gap-4 md:grid-cols-3">
        <a class="riso-hover riso-shadow border-2 border-ink bg-paper p-6" href={withBase('/blog/')}>
          <i class="ph-fill ph-article text-3xl text-brand" aria-hidden="true"></i>
          <h3 class="display-sm mt-4 text-ink">Blog</h3>
          <p class="mt-2 font-body leading-7 text-muted">Kabar, gagasan, dan catatan dari komunitas.</p>
          <span class="meta-row mt-5 block font-bold text-brand">Baca tulisan →</span>
        </a>
        <a class="riso-hover riso-shadow border-2 border-ink bg-paper p-6" href={withBase('/users/')}>
          <i class="ph-fill ph-users-three text-3xl text-brand" aria-hidden="true"></i>
          <h3 class="display-sm mt-4 text-ink">Top User</h3>
          <p class="mt-2 font-body leading-7 text-muted">Lihat pemilik proyek dan akumulasi dampaknya.</p>
          <span class="meta-row mt-5 block font-bold text-brand">Lihat peringkat →</span>
        </a>
        <a class="riso-hover riso-shadow border-2 border-ink bg-[#fbe9f1] p-6" href={withBase('/donasi/')}>
          <i class="ph-fill ph-heart text-3xl text-[#bf3989]" aria-hidden="true"></i>
          <h3 class="display-sm mt-4 text-ink">Donasi, sponsor & CSR</h3>
          <p class="mt-2 font-body leading-7 text-muted">Dukung infrastruktur, pengetahuan, event, dan proyek potensial.</p>
          <span class="meta-row mt-5 block font-bold text-[#9e2f73]">Lihat bentuk dukungan →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-t-[3px] border-ink bg-brand py-16 md:py-20">
    <div class="mx-auto flex w-[min(1120px,calc(100%-32px))] items-end justify-between gap-8 max-md:flex-col max-md:items-start">
      <div class="max-w-3xl">
        <div class="mb-5 flex items-center gap-3"><span class="sticker">Ruang Belajar</span><span class="meta-row text-paper">// karya Onno W. Purbo</span></div>
        <h2 class="display-md text-paper">Baca pengetahuan teknologi terbuka.</h2>
        <p class="mt-5 max-w-2xl font-body text-xl leading-8 text-paper">Koleksi awal karya Onno W. Purbo untuk dibaca langsung dan diunduh dari sumbernya.</p>
      </div>
      <BaseButton href="/belajar/" variant="light">Buka koleksi</BaseButton>
    </div>
  </section>
</BaseLayout>
