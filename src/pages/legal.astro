---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseButton from '../components/BaseButton.astro';
import PageHeader from '../components/PageHeader.astro';
import { withBase } from '../lib/urls';

const policies = [
  {
    icon: 'ph-code',
    title: 'Lisensi Kode',
    desc: 'Kode sumber website ini dilisensikan di bawah MIT License. Setiap proyek dalam direktori memiliki lisensinya sendiri seperti tercantum pada metadata repository asal.',
    link: 'https://github.com/IndopenSource/indopensource.org/blob/main/LICENSE',
    isExternal: true
  },
  {
    icon: 'ph-shield-warning',
    title: 'Pelaporan Kerentanan',
    desc: 'Jangan membuka issue publik untuk laporan sensitif. Ikuti halaman Security atau kirim detail melalui kanal privat yang tersedia.',
    link: '/security/',
    isExternal: false
  },
  {
    icon: 'ph-user-circle',
    title: 'Privasi & Data',
    desc: 'Website publik ini dapat dibaca tanpa akun atau formulir data pribadi. Saat mengikuti tautan ke GitHub atau layanan lain, kebijakan layanan tersebut berlaku.',
    link: 'https://github.com/IndopenSource/indopensource.org',
    isExternal: true
  }
];

const disclaimers = [
  'Konten yang dikurasi adalah tanggung jawab masing-masing maintainer proyek.',
  'Kami tidak memberikan nasihat hukum atau lisensi profesional.',
  'Tautan ke proyek eksternal tidak merupakan endorsement.',
  'Entri direktori dapat diperbarui atau dihapus jika tidak lagi memenuhi aturan kontribusi.'
];
---

<BaseLayout title="Legal & Kebijakan - IndopenSource" description="Informasi lisensi, kebijakan privasi, dan ketentuan hukum komunitas IndopenSource.">
  <PageHeader eyebrow="Legal" title="Ketentuan dan kebijakan komunitas.">
    <p>Transparansi adalah bagian dari open source. Halaman ini menjelaskan lisensi, kebijakan, dan ketentuan yang berlaku di ekosistem IndopenSource.</p>
  </PageHeader>

  <section class="grain border-b-[3px] border-ink bg-brand-dark py-16 text-paper md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <span class="sticker">Transparansi</span>
      <p class="pull-quote mt-5 max-w-4xl text-paper">Terbuka tentang <span class="text-sun">ketentuan</span>, seperti kami terbuka tentang kode.</p>
    </div>
  </section>

  <section class="bg-paper py-16 md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="mb-10">
        <span class="sticker">Kebijakan</span>
        <h2 class="display-md mt-4">Lisensi dan ketentuan.</h2>
        <p class="mt-3 max-w-2xl font-body text-lg leading-8 text-muted">Informasi lengkap tentang lisensi konten, kode, dan kebijakan hukum yang berlaku.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {policies.map((p) => {
          const href = p.isExternal ? p.link : withBase(p.link);
          return (
            <article class="riso-shadow border-2 border-ink bg-canvas p-6">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg border-2 border-ink bg-sun">
                  <i class:list={['ph-fill text-2xl text-brand', p.icon]} aria-hidden="true"></i>
                </div>
                <div class="flex-1">
                  <h3 class="font-display text-xl font-bold text-ink">{p.title}</h3>
                  <p class="mt-3 font-body leading-7 text-muted">{p.desc}</p>
                  <a class="meta-row mt-4 inline-block font-semibold text-brand underline decoration-2 underline-offset-4 hover:text-accent" href={href}>Selengkapnya →</a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="border-y-[3px] border-ink bg-canvas py-16 md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="mb-10">
        <span class="sticker">Catatan penting</span>
        <h2 class="display-md mt-4">Disclaimer komunitas.</h2>
      </div>
      <div class="riso-shadow border-2 border-ink bg-paper p-6 md:p-8">
        <ul class="space-y-3 font-body text-lg leading-8 text-muted">
          {disclaimers.map((d) => (
            <li class="flex gap-3">
              <i class="ph-fill ph-info text-xl text-brand flex-shrink-0 mt-1" aria-hidden="true"></i>
              <span>{d}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-paper py-16 md:py-20">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="riso-shadow border-2 border-ink bg-sun p-8 md:p-12">
        <span class="sticker">Pertanyaan hukum?</span>
        <h2 class="display-md mt-4 text-ink">Hubungi tim legal.</h2>
        <p class="mt-4 max-w-2xl font-body text-lg leading-8 text-ink">Untuk pertanyaan tentang lisensi, hak cipta, atau masalah hukum lainnya, silakan hubungi tim kami.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <BaseButton href="mailto:legal@indopensource.org">Email Tim Legal</BaseButton>
          <BaseButton href={withBase('/kode-etik/')} variant="secondary">Kode Etik</BaseButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
