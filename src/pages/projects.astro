---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const languages = [...new Set(projects.map((project) => project.language).filter(Boolean))].slice(0, 12);
---

<BaseLayout title="Projects - IndopenSource">
  <PageHeader eyebrow="Projects" title="Direktori proyek Indonesia.">
    <p>
      Daftar awal halaman ini disinkronkan dari
      <a class="font-bold text-brand hover:text-brand-dark" href="https://github.com/IndopenSource/awesome-indonesia">IndopenSource/awesome-indonesia</a>.
    </p>
    <div class="mt-4 flex flex-wrap gap-2 text-sm">
      <span class="rounded-full border border-line px-2 py-1">{projects.length} projects</span>
      {languages.map((language) => <span class="rounded-full border border-line px-2 py-1">{language}</span>)}
    </div>
  </PageHeader>
  <section class="py-18">
    <div class="mx-auto grid w-[min(1120px,calc(100%-32px))] grid-cols-2 gap-4 max-lg:grid-cols-1">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
