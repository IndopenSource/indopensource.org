---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProjectsDirectory from '../components/ProjectsDirectory.astro';
import { rankProjectOwners, type Project } from '../lib/projects';
import { withBase } from '../lib/urls';
import projectsData from '../data/projects.json';
import legacyData from '../data/legacy.json';
import revivalData from '../data/revival.json';

const projects = projectsData as Project[];
const legacyProjects = legacyData as any[];
const revivalProjects = revivalData as any[];

// Stars/forks of `syncFailed` stubs are placeholder zeros, not real counts
// (CC-10). Aggregate only over successfully refreshed repos so the totals are
// honest, and surface how many could not be refreshed.
const refreshedProjects = projects.filter((project) => !project.syncFailed);
const unavailableCount = projects.length - refreshedProjects.length;
const languages = [...new Set(refreshedProjects.map((project) => project.language).filter(Boolean))].slice(0, 12);
const totalStars = refreshedProjects.reduce((sum, project) => sum + project.stars, 0);
const totalForks = refreshedProjects.reduce((sum, project) => sum + project.forks, 0);
const latestUpdate = refreshedProjects
  .map((project) => project.pushedAt || project.updatedAt)
  .filter(Boolean)
  .sort()
  .at(-1);
const latestUpdateLabel = latestUpdate
  ? new Intl.DateTimeFormat('id-ID', { dateStyle: 'medium' }).format(new Date(latestUpdate))
  : '';
const ownerAvatarUrl = (owner: string) => `https://avatars.githubusercontent.com/${encodeURIComponent(owner)}?size=80`;
const topUsers = rankProjectOwners(refreshedProjects).slice(0, 5);
---

<BaseLayout
  title="Proyek - IndopenSource"
  description="Direktori proyek open source Indonesia dari awesome-indonesia dengan filter, pagination, release, topic, dan metadata repo."
>
  <PageHeader eyebrow="Proyek" title="Direktori proyek Indonesia.">
    <p>
      Daftar awal halaman ini disinkronkan dari
      <a class="font-semibold text-brand underline decoration-2 underline-offset-2 hover:text-accent" href="https://github.com/IndopenSource/awesome-indonesia">IndopenSource/awesome-indonesia</a>.
    </p>
    <div class="meta-row mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 font-semibold text-ink">
      <span class="rounded-md border border-line bg-canvas px-2.5 py-1 text-xs">{projects.length} proyek</span>
      <span class="rounded-md border border-line bg-canvas px-2.5 py-1 text-xs">★ {totalStars.toLocaleString('id-ID')}</span>
      {languages.map((language) => <span class="text-brand-dark">{language}</span>)}
    </div>
    {unavailableCount > 0 && (
      <p class="mt-4 font-body text-base leading-7 text-muted" role="status">
        {unavailableCount.toLocaleString('id-ID')} repo belum bisa diperbarui saat sinkronisasi terakhir, jadi tidak dihitung dalam akumulasi stars/forks di bawah.
      </p>
    )}
    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-xl border border-line bg-paper p-5 shadow-sm">
        <span class="meta-row block font-bold uppercase tracking-[0.06em] text-muted">Akumulasi stars</span>
        <strong class="mt-2 block font-mono text-3xl font-bold text-ink">{totalStars.toLocaleString('id-ID')}</strong>
      </div>
      <div class="rounded-xl border border-line bg-paper p-5 shadow-sm">
        <span class="meta-row block font-bold uppercase tracking-[0.06em] text-muted">Akumulasi forks</span>
        <strong class="mt-2 block font-mono text-3xl font-bold text-ink">{totalForks.toLocaleString('id-ID')}</strong>
      </div>
      <div class="rounded-xl border border-line bg-paper p-5 shadow-sm">
        <span class="meta-row block font-bold uppercase tracking-[0.06em] text-muted">Update terbaru</span>
        <strong class="mt-2 block font-mono text-xl font-bold text-ink">{latestUpdateLabel || '-'}</strong>
      </div>
    </div>
  </PageHeader>

  <section class="border-b border-line bg-paper py-10">
    <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
      <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
        <div>
          <span class="sticker">Top user</span>
          <h2 class="display-sm mt-3 text-ink">Lima penggerak teratas.</h2>
        </div>
        <a class="inline-flex items-center gap-2 font-semibold text-brand underline decoration-2 underline-offset-4 hover:text-brand-dark" href={withBase('/users/')}>
          Lihat semua <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="overflow-x-auto pb-4 [scrollbar-width:thin]">
        <div class="flex w-max min-w-full snap-x snap-mandatory gap-3">
          {topUsers.map((user, index) => (
            <a class="riso-hover flex w-[min(260px,78vw)] shrink-0 snap-start items-center gap-3 border-2 border-ink bg-canvas p-3" href={`https://github.com/${user.owner}`} target="_blank" rel="noopener noreferrer">
              <span class="font-mono text-sm font-bold text-brand">{index + 1}</span>
              <img class="size-10 shrink-0 rounded-lg border border-line bg-paper object-cover" src={user.avatarUrl} alt="" width="40" height="40" loading="lazy" decoding="async" />
              <span class="min-w-0">
                <strong class="block truncate font-display text-sm text-ink">{user.owner}</strong>
                <span class="meta-row block text-muted">★ {user.stars.toLocaleString('id-ID')}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
  <ProjectsDirectory projects={projects} />

  {legacyProjects.length > 0 && (
    <section class="border-t border-line bg-canvas py-16 md:py-20">
      <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
        <div class="mb-10">
          <span class="sticker">Legacy</span>
          <h2 class="display-md mt-4">Proyek warisan.</h2>
          <p class="mt-3 max-w-2xl font-body text-lg leading-8 text-muted">
            Resource dan proyek non-app open source Indonesia yang masih relevan sebagai referensi pembelajaran.
          </p>
          <a class="mt-4 inline-flex items-center gap-2 font-semibold text-brand underline decoration-2 underline-offset-4 hover:text-brand-dark" href="https://github.com/IndopenSource/awesome-indonesia-legacy" target="_blank" rel="noopener noreferrer">Buka repository Legacy <span aria-hidden="true">↗</span></a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {legacyProjects.map((repo) => (
            <a
              class="riso-hover riso-shadow block border-2 border-ink bg-paper p-5"
              href={repo.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex min-w-0 items-center gap-3">
                  <img class="size-10 shrink-0 rounded-lg border border-line bg-canvas object-cover" src={ownerAvatarUrl(repo.owner)} alt="" width="40" height="40" loading="lazy" decoding="async" />
                  <div class="min-w-0">
                    <h3 class="break-words font-display text-lg font-bold text-ink">{repo.name}</h3>
                    <span class="meta-row mt-0.5 block text-brand-dark">oleh {repo.owner}</span>
                  </div>
                </div>
                <i class="ph ph-arrow-square-out text-xl text-muted" aria-hidden="true"></i>
              </div>
              <p class="mt-2 font-body text-sm leading-6 text-muted line-clamp-2">{repo.description || 'Tidak ada deskripsi'}</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-xs text-muted">
                {repo.language && <span class="flex items-center gap-1"><i class="ph ph-code text-sm" aria-hidden="true"></i>{repo.language}</span>}
                <span class="flex items-center gap-1"><i class="ph ph-star text-sm" aria-hidden="true"></i>{(repo.stars ?? 0).toLocaleString('id-ID')}</span>
                <span class="flex items-center gap-1"><i class="ph ph-git-fork text-sm" aria-hidden="true"></i>{(repo.forks ?? 0).toLocaleString('id-ID')}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {revivalProjects.length > 0 && (
    <section class="border-t border-line bg-paper py-16 md:py-20">
      <div class="mx-auto w-[min(1120px,calc(100%-32px))]">
        <div class="mb-10">
          <span class="sticker">Revival</span>
          <h2 class="display-md mt-4">Proyek potensial untuk dihidupkan kembali.</h2>
          <p class="mt-3 max-w-2xl font-body text-lg leading-8 text-muted">
            Proyek open source Indonesia yang butuh kontribusi untuk aktif kembali.
          </p>
          <a class="mt-4 inline-flex items-center gap-2 font-semibold text-brand underline decoration-2 underline-offset-4 hover:text-brand-dark" href="https://github.com/IndopenSource/awesome-indonesia-revival" target="_blank" rel="noopener noreferrer">Buka repository Revival <span aria-hidden="true">↗</span></a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {revivalProjects.map((repo) => (
            <a
              class="riso-hover riso-shadow block border-2 border-ink bg-canvas p-5"
              href={repo.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex min-w-0 items-center gap-3">
                  <img class="size-10 shrink-0 rounded-lg border border-line bg-paper object-cover" src={ownerAvatarUrl(repo.owner)} alt="" width="40" height="40" loading="lazy" decoding="async" />
                  <div class="min-w-0">
                    <h3 class="break-words font-display text-lg font-bold text-ink">{repo.name}</h3>
                    <span class="meta-row mt-0.5 block text-brand-dark">oleh {repo.owner}</span>
                  </div>
                </div>
                <i class="ph ph-arrow-square-out text-xl text-muted" aria-hidden="true"></i>
              </div>
              <p class="mt-2 font-body text-sm leading-6 text-muted line-clamp-2">{repo.description || 'Tidak ada deskripsi'}</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-xs text-muted">
                {repo.language && <span class="flex items-center gap-1"><i class="ph ph-code text-sm" aria-hidden="true"></i>{repo.language}</span>}
                <span class="flex items-center gap-1"><i class="ph ph-star text-sm" aria-hidden="true"></i>{(repo.stars ?? 0).toLocaleString('id-ID')}</span>
                <span class="flex items-center gap-1"><i class="ph ph-git-fork text-sm" aria-hidden="true"></i>{(repo.forks ?? 0).toLocaleString('id-ID')}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
