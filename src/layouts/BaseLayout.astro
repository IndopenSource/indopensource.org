---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const {
  title = 'IndopenSource',
  description = 'Roadmap website IndopenSource untuk proyek open source Indonesia.'
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }brand/favicon.ico`} sizes="any" />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }brand/favicon-32.png`} type="image/png" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/') }brand/apple-touch-icon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
